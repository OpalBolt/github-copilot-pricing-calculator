{% import 'macros.html.j2' as m %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GitHub Copilot · Token cost calculator</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600&family=Source+Serif+4:ital,wght@1,500&display=swap" rel="stylesheet" />
  {% include 'styles.css.j2' %}
</head>
<body>

<!-- ── Header ──────────────────────────────────────────────── -->
<header class="page-header">
  <p class="eyebrow">GitHub Copilot · AI credits</p>
  <h1>Token cost calculator</h1>
  <p>Compare what every model actually costs in AI credits before you commit to one. All prices are per 1 million tokens · 1 AI credit = $0.01 USD.</p>
  <p class="meta">Source: <a href="https://docs.github.com/en/copilot/reference/copilot-billing/models-and-pricing" target="_blank">docs.github.com · models and pricing</a> · Data fetched: <span id="fetch-date">—</span></p>
</header>

<!-- ── Main ────────────────────────────────────────────────── -->
<main>

  <!-- Controls -->
  <div class="controls">
    <h2>Configure your estimate</h2>
    
    <!-- Tabs -->
    <div class="tabs-nav">
      <button class="tab-btn active" data-tab="pricing-tab">Pricing & Compare</button>
      <button class="tab-btn" data-tab="guide-tab">Task Guide</button>
      <button class="tab-btn" data-tab="strategies-tab">AI strategies</button>
    </div>
    
    <!-- Pricing Tab -->
    <div id="pricing-tab" class="tab-content active">
      <!-- Profile Presets -->
      <div class="profile-presets">
        <span class="profile-label">Quick presets:</span>
        <div class="profile-buttons">
          <button class="profile-btn" data-profile="superuser">Superuser/Developer</button>
          <button class="profile-btn" data-profile="regular">Regular User</button>
        </div>
      </div>
      
      <div class="controls-grid">
        {{ m.input_group('total-tokens', 'Total tokens', 1000000, 1, None, 100000) }}
        {{ m.input_group('input-pct', 'Input %', 1.45, 0, 100, 0.1) }}
        {{ m.input_group('cached-pct', 'Cached input %', 96.62, 0, 100, 0.1) }}
        {{ m.input_group('output-pct', 'Output %', 1.93, 0, 100, 0.1) }}
        {{ m.input_group('budget-amount', 'Budget ($)', 80, 0, None, 0.01) }}
      </div>
      <div class="summary-chips" id="summary-chips"></div>
      <div id="pct-warning" style="display: none; margin-top: 12px; padding: 8px 12px; background: #FEF9C3; border: 1px solid #EAB308; border-radius: 4px; font-size: 13px; color: #854D0E;">
        ⚠️ Input, Cached, and Output percentages must sum to 100%
      </div>
    </div>
    
    <!-- Task Guide Tab (placeholder, will be filled by JS) -->
    <div id="guide-tab" class="tab-content">
      <div id="guide-content"></div>
    </div>

    <div id="strategies-tab" class="tab-content">
      <section class="explanation-section" aria-labelledby="explanation-heading">
        <h2 id="explanation-heading">Understanding token types</h2>
        <p class="explanation-intro">
          The same total token count can cost very differently depending on how much of it is fresh context, reused context, or model output.
        </p>
        <dl class="explanation-grid">
          <div class="explanation-card explanation-input">
            <dt>Input tokens</dt>
            <dd>
              New prompt/context tokens sent on a fresh request — like instructions, code, or chat history the model has to read from scratch.
              They cost more than cached input because the model must process the full context again.
            </dd>
          </div>
          <div class="explanation-card explanation-cached">
            <dt>Cached tokens</dt>
            <dd>
              Reused input from the same session, such as repeated system text or unchanged file context.
              Providers can reuse prior computation here, so cached input is much cheaper and often makes up most of a coding session's token mix.
            </dd>
          </div>
          <div class="explanation-card explanation-output">
            <dt>Output tokens</dt>
            <dd>
              Tokens the model generates in its reply.
              Generation is sequential and compute-heavy, so output usually has the highest per-token rate even when it is a small share of total tokens.
            </dd>
          </div>
        </dl>
        <h3 class="explanation-subheading">Table columns</h3>
        <dl class="explanation-grid explanation-grid-cols-4">
          <div class="explanation-card">
            <dt>Est. cost</dt>
            <dd>
              The estimated USD cost for one run of your configured token mix. It combines your total tokens with the Input / Cached / Output percentages and each model's rates.
            </dd>
          </div>
          <div class="explanation-card">
            <dt>Runs</dt>
            <dd>
              How many times you could repeat that exact token mix within your budget. This is Budget ÷ Est. cost, so larger budgets or cheaper models increase the count.
            </dd>
          </div>
          <div class="explanation-card">
            <dt>Tokens</dt>
            <dd>
              The total raw token volume your budget can afford for that model. It is Runs × Total tokens, so it moves with Runs but tells you the overall token capacity.
            </dd>
          </div>
          <div class="explanation-card">
            <dt>Relative cost</dt>
            <dd>
              A bar that shows cost relative to the most expensive model currently visible. The value is displayed in AI credits, where 1 credit equals $0.01.
            </dd>
          </div>
        </dl>
        <p class="explanation-note">
          That is why the Input / Cached / Output sliders matter so much for the Est. cost column: the same total can land at a very different price once each token type uses its own $/1M rate.
        </p>
      </section>

      <h2>Making the most of your tokens</h2>
      <p class="explanation-intro">
        Practical habits for keeping token usage, and cost, under control across longer sessions and larger prompts.
      </p>

      <div class="task-card">
        <h3>Long-running sessions &amp; coding harnesses</h3>
        <ul>
          <li>Summarize or compact conversation history periodically instead of letting a session's transcript grow indefinitely. Every additional turn re-sends the full history as input tokens unless it's cached, so unbounded history quietly compounds cost.</li>
          <li>Break large bodies of work into smaller, focused sub-tasks (or sub-agents) rather than one continuous mega-session; each sub-task starts with a smaller, more relevant context instead of dragging along everything that came before.</li>
          <li>Close out or clear context you no longer need (finished files, resolved errors, old tool output) so it doesn't keep getting resent turn after turn.</li>
          <li>Match the model to the task: reserve your most capable (and often priciest) model for genuinely hard reasoning or debugging, and use a faster/cheaper model for repetitive, mechanical, or well-scoped steps. The Task Guide and pricing table on this page are built to help with exactly that decision.</li>
        </ul>
      </div>

      <div class="task-card">
        <h3>Avoiding excessive context usage</h3>
        <ul>
          <li>Don't paste entire files, logs, or command output when only a specific snippet is relevant. Extract just the part that matters.</li>
          <li>Use targeted search (grep/find) instead of dumping whole directories into a prompt; pull in only the files you actually need to reason about.</li>
          <li>Keep an eye on how much of the model's context window you're using. Leaving headroom generally keeps responses more focused and avoids hitting hard context limits mid-task.</li>
          <li>In long sessions, periodically ask for or trigger a summary/reset of history rather than letting every prior turn ride along forever.</li>
        </ul>
      </div>

      <div class="task-card">
        <h3>Put the most relevant information first</h3>
        <ul>
          <li>Models tend to attend most reliably to the start and end of a prompt, with information buried in the middle more likely to get lost. Lead with the most important instructions, constraints, or facts rather than burying them mid-prompt.</li>
          <li>This also pairs naturally with prompt caching: stable content that doesn't change between requests (system prompts, reference docs, style guides) is what typically gets reused/cached when placed in a consistent prefix, while newer or frequently-changing details belong later in the prompt.</li>
          <li>Structure prompts with clear sections or headings so critical information is easy for the model (and you) to find, instead of one unbroken wall of text.</li>
          <li>Restate the actual task/question clearly right after any stable, cached prefix, and again at the end of a long prompt, so it doesn't get lost without disrupting what gets cached.</li>
        </ul>
      </div>

      <div class="task-card">
        <h3>Other tips</h3>
        <ul>
          <li>Batch related questions or steps into a single request instead of many small back-and-forth turns. Each new turn re-sends the accumulated context, so fewer, well-composed turns can be more efficient.</li>
          <li>Only reach for long-context-tier models when you actually need the extra window: that tier is usually priced higher than the model's default tier.</li>
          <li>Use the Runs / Tokens columns on the Pricing tab to sanity-check whether a workflow is affordable at scale before committing to it broadly.</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Everything below only belongs to the "Pricing & Compare" tab -->
  <div id="pricing-tab-body" class="tab-content active">
    <!-- Filters -->
    <div class="filters-bar">
      {{ m.filter_chip_group('filter-provider', 'Provider', ['all', 'OpenAI', 'Anthropic', 'Google', 'Fine-tuned (GitHub)', 'Microsoft', 'Moonshot AI'], 'all') }}
      {{ m.filter_chip_group('filter-category', 'Category', ['all', 'Powerful', 'Versatile', 'Lightweight'], 'all') }}
      {{ m.filter_chip_group('filter-status', 'Status', ['all', 'GA', 'preview'], 'all') }}
      <div id="filter-task-area-group" class="filter-group" style="display: none;">
        <span class="filter-label">Task area</span>
        <div class="filter-chips" id="filter-task-area"></div>
      </div>
      <div class="search-wrap">
        <input type="search" id="search-input" placeholder="Search model name…" />
      </div>
      <div class="column-toggle-group" aria-label="Table columns">
        <span class="filter-label">Columns</span>
        <div class="column-toggle-chips">
          <label class="column-toggle-chip" for="toggle-input-col">
            <input type="checkbox" id="toggle-input-col" checked />
            <span>Input</span>
          </label>
          <label class="column-toggle-chip" for="toggle-cached-col">
            <input type="checkbox" id="toggle-cached-col" checked />
            <span>Cached</span>
          </label>
          <label class="column-toggle-chip" for="toggle-output-col">
            <input type="checkbox" id="toggle-output-col" checked />
            <span>Output</span>
          </label>
        </div>
      </div>
    </div>

    <!-- Table meta row -->
    <div class="table-meta" id="pricing-table-meta">
      <span class="table-meta-count" id="row-count"></span>
    </div>

    <!-- Unified table -->
    <div class="table-wrapper" id="pricing-table-wrapper">
      <table id="main-table">
        <thead>
          <tr>
            <th style="width:36px;padding:10px 8px"></th>
            {{ m.table_header_cell('name', 'Model', false) }}
            {{ m.table_header_cell('provider', 'Provider', false) }}
            {{ m.table_header_cell('category', 'Category', false) }}
            <th class="sortable num col-input" data-col="input">Input <span class="sort-icon">↕</span></th>
            <th class="sortable num col-cached" data-col="cached">Cached <span class="sort-icon">↕</span></th>
            <th class="sortable num col-output" data-col="output">Output <span class="sort-icon">↕</span></th>
            {{ m.table_header_cell('cost', 'Est. cost', true, 'Estimated USD cost for one run of your configured token mix (Total tokens × Input/Cached/Output %).') }}
            {{ m.table_header_cell('runs', 'Runs', true, 'How many times you could repeat your configured token mix within your budget (Budget ÷ Est. cost).') }}
            {{ m.table_header_cell('tokens', 'Tokens', true, 'Total tokens affordable within your budget for this model (Runs × Total tokens).') }}
            <th class="bar-cell" title="Bar length shows cost relative to the most expensive model currently shown. Value is in AI credits (1 credit = $0.01).">Relative cost</th>
          </tr>
        </thead>
        <tbody id="table-body"></tbody>
      </table>
      <div class="no-results" id="no-results">No models match your filters.</div>
    </div>

    <!-- Task area legend -->
    <div class="task-area-legend" id="task-area-legend" style="display:none">
      <span class="legend-label">Task area:</span>
      <div class="legend-items" id="legend-items"></div>
    </div>

    <p class="page-note">
      Est. cost = (input tokens × input rate + cached tokens × cached rate + output tokens × output rate) ÷ 1M, based on your token split above.
      Input / Cached / Output rates are priced per 1M tokens. Runs = Budget ÷ Est. cost. Tokens = Runs × Total tokens.
      Code completions and next-edit suggestions are not billed in AI credits.
      · <a href="https://docs.github.com/en/copilot/reference/copilot-billing/models-and-pricing" target="_blank">Source pricing →</a>
    </p>
  </div>
</main>

<footer class="page-footer">
  <span>GitHub Copilot · Token cost calculator · Data sourced from GitHub docs</span>
  <a href="https://docs.github.com/en/copilot/reference/copilot-billing/models-and-pricing" target="_blank">View source pricing →</a>
</footer>

<!-- ── Compare tray ────────────────────────────────────────── -->
<div id="compare-tray" role="region" aria-label="Model comparison">
  <div class="tray-header">
    <span class="tray-title">Comparing <span id="tray-count">0</span> models</span>
    <div class="tray-actions">
      <button class="tray-clear" onclick="clearCompare()">Clear all</button>
    </div>
  </div>
  <div class="tray-cards" id="tray-cards"></div>
</div>

{% include 'app.js.j2' %}

</body>
</html>
